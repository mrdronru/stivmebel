#!/bin/bash

SITE_DIR="/var/www/u2240000/data/www/stivmebel.ru"

cd "$SITE_DIR" || { echo "Ошибка: директория не найдена"; exit 1; }

MSG="Изменение от $(date '+%d.%m.%Y %H:%M')"

git add .

if git diff --quiet && git diff --cached --quiet; then
  echo "Нет изменений для коммита."
  exit 0
fi

git commit -m "$MSG"
git push

echo "✓ Готово: $MSG"
